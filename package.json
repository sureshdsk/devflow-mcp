{
  "name": "@sureshdsk/devflow-mcp",
  "version": "3.0.2",
  "description": "Context-First Kanban for AI Agents - MCP server with web UI for managing AI agent workflows",
  "author": "DevFlow Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sureshdsk/devflow-mcp.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "kanban",
    "task-management",
    "claude",
    "cursor",
    "workflow",
    "project-management"
  ],
  "packageManager": "pnpm@10.14.0",
  "bin": {
    "devflow": "./bin/devflow.js",
    "devflow-mcp": "./bin/devflow.js"
  },
  "files": [
    "bin",
    "src",
    "dist",
    "drizzle",
    "scripts",
    "tsconfig.json",
    "drizzle.config.ts",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev:server": "tsx src/server/start.ts",
    "dev:client": "vite",
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:client\"",
    "build:client": "vite build",
    "build:server": "tsup",
    "build": "pnpm build:client && pnpm build:server",
    "start": "node dist/server/start.js",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:init": "node scripts/init-db.js",
    "mcp": "tsx src/mcp/server.ts",
    "release:patch": "npm version patch -m 'release: %s'",
    "release:minor": "npm version minor -m 'release: %s'",
    "release:major": "npm version major -m 'release: %s'",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run build",
    "postinstall": "node scripts/postinstall.js",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hono/node-server": "^1.14.1",
    "@libsql/client": "^0.17.0",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.90.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.7.11",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.563.0",
    "mermaid": "^11.12.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.6.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.4.0",
    "tsx": "^4.19.4",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.17",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.1.2",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.17",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vite": "^6.3.5"
  }
}
